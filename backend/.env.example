# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kodipay
DB_USER=your_username
DB_PASSWORD=your_password

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_key

# M-Pesa Integration (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# SMS Integration (AfricasTalking)
SMS_PROVIDER=africastalking
SMS_USERNAME=your_sms_username
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=KodiPay
SMS_ENV=sandbox

# OpenAI Configuration (Chatbot)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500

# Firebase Configuration (Push Notifications & Storage)
# Note: FIREBASE_SERVICE_ACCOUNT should be a JSON string of your service account key file
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
